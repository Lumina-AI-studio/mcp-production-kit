    {
      "name": "status:read",
      "description": "Read access to the built-in get_service_status tool.",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "true"
      },
      "protocolMappers": [
        {
          "name": "mcp-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.custom.audience": "http://localhost:3000/mcp",
            "access.token.claim": "true",
            "id.token.claim": "false",
            "introspection.token.claim": "true"
          }
        }
      ]
    }
  ],
  "clients": [
    {
      "clientId": "inspector",
      "name": "MCP Inspector (public, PKCE)",
      "description": "Public client for the MCP Inspector OAuth flow.",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "fullScopeAllowed": false,
      "redirectUris": [
        "http://localhost:6274/*",
        "http://127.0.0.1:6274/*"
      ],
      "webOrigins": [
        "http://localhost:6274",
        "http://127.0.0.1:6274"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "defaultClientScopes": [],
      "optionalClientScopes": [
        "offline_access",
        "customers:read",
        "orders:read",
        "invoices:read",
        "refunds:write",
        "orders:write",
        "status:read"
      ]
    },
    {
      "clientId": "demo-agent",
      "name": "Demo agent (confidential, client_credentials)",
      "description": "Confidential client for client_credentials \u2014 tokens carry all six scopes by default.",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "demo-secret",
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "fullScopeAllowed": false,
      "defaultClientScopes": [
        "customers:read",
        "orders:read",
        "invoices:read",
        "refunds:write",
        "orders:write",
        "status:read"
      ],
      "optionalClientScopes": []
    }
  ],
  "users": [
    {
      "username": "demo",
      "enabled": true,
      "emailVerified": true,
      "email": "demo@nordwind.example",
      "firstName": "Demo",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "demo",
          "temporary": false
        }
      ],
      "realmRoles": ["default-roles-mcp-example"]
    }
  ]
}